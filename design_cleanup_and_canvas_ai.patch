+                  background: h.status === 'applied' ? 'rgba(var(--color-success-rgb), 0.15)' : 'rgba(255,255,255,0.06)',
+                  color: h.status === 'applied' ? 'var(--color-success)' : 'var(--text-tertiary)',
+                }}>
+                  {h.status === 'applied' ? '已应用' : '已放弃'}
+                </span>
